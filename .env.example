# =========================================================================
# SYSTEM ENVIRONMENT VARIABLES (Vercel / Production)
# =========================================================================

# 1. Supabase Public URL
# Description: The URL of your Supabase project REST API.
NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"

# 2. Supabase Anon Key
# Description: The public anonymous key for client-side Supabase interactions.
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# 3. Supabase Service Role Key
# Description: The secret key with full database access (bypasses RLS).
# NEVER expose this to the browser.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# 4. Other Configuration
NODE_ENV="production"
